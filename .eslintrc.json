{
  "env": {
    "browser": true,
    "es2021": true,
    "cypress/globals": true,
    "node": true
  },
  "extends": ["eslint:recommended", "plugin:cypress/recommended"],
  "plugins": ["cypress"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-expressions": "off"
  }
}
